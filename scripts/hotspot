#!/system/bin/sh

LOG_FILE="/data/adb/php8/files/tmp/hotspot.log"

log() {
    echo "[$(date '+%H:%M:%S')] $1" >> "$LOG_FILE"
}

log "AWD Modem: Menerima perintah update konfigurasi."

# 1. Matikan Hotspot dan WiFi
log "AWD Modem: Mematikan koneksi tethering..."
# Metode ifconfig dari user (wlan0, wlan1, ap0, dll) khusus WiFi
for iface in wlan0 wlan1 ap0 swlan; do
    ifconfig $iface down >/dev/null 2>&1
done
# Matikan WiFi
svc wifi disable >/dev/null 2>&1

# 2. Tunggu sebentar agar sistem melepaskan konfigurasi lama
log "AWD Modem: Menunggu sistem sinkronisasi..."
sleep 3

# 3. Nyalakan kembali Hotspot (AWD Modem LSPosed akan mengambil alih injeksi data di sini)
log "AWD Modem: Menyalakan kembali Hotspot..."

# Perintah dari user untuk Android 11+
service call tethering 4 null s16 random >/dev/null 2>&1
# Perintah dari user untuk Android 10 ke bawah
service call connectivity 24 i32 0 i32 0 i32 0 s16 random >/dev/null 2>&1

log "AWD Modem: Hotspot berhasil di-restart dengan konfigurasi baru!"
echo "SUCCESS"
