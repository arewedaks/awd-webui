#!/system/bin/sh

# 1. SETUP & LOAD CONFIG
scripts=`realpath $0`
scripts_dir=`dirname ${scripts}`

if [ -f "/data/adb/php8/files/config/php.config" ]; then
    . /data/adb/php8/files/config/php.config
else
    echo "Error: Config file not found"
    exit 1
fi

# 2. DEFINISI VARIABEL PENTING
# Pastikan path ini sesuai dengan instalasi Termux standar
TERMUX_HOME="/data/data/com.termux/files/home"
TERMUX_USR="/data/data/com.termux/files/usr"
BASH_BIN="${tmux_bin_path}/bash"
TARGET_BIN="${tmux_bin_path}/tmux"

# 3. AMBIL UID PEMILIK TERMUX
# Kita ambil UID dari file bash termux agar permission sesuai
if [ -f "$BASH_BIN" ]; then
    user_uid=`stat -c %u ${BASH_BIN}`
else
    echo "Error: Bash Termux binary not found at $BASH_BIN"
    exit 1
fi

# 6. EKSEKUSI BASH / TMUX SEBAGAI USER TERMUX
# Karena Magisk 'su' selalu melucuti LD_LIBRARY_PATH demi keamanan, 
# kita mengeksekusi script wrapper statis yang sudah dipindahkan ke folder Termux.
# Pastikan script install_ttyd_wrapper.sh telah dijalankan saat pemasangan modul!

WRAPPER_SCRIPT="${TERMUX_USR}/tmp/awd_webui_wrapper.sh"

if [ ! -f "$WRAPPER_SCRIPT" ]; then
    if [ -f "${scripts_dir}/awd_webui_wrapper.sh" ]; then
        cp -f "${scripts_dir}/awd_webui_wrapper.sh" "$WRAPPER_SCRIPT"
        chmod 0755 "$WRAPPER_SCRIPT"
        chown $user_uid:$user_uid "$WRAPPER_SCRIPT"
    else
        echo "Error: Wrapper script tidak ditemukan di ${scripts_dir}!"
        # Fallback darurat
        exec su -m -g $user_uid -G 3003 -G 3004 -G 9997 -G 1015 $user_uid -s $BASH_BIN -- -l
    fi
fi

# Eksekusi wrapper menggunakan su. PTY otomatis diwariskan dari ttyd!
exec su -g $user_uid -G 3003 -G 3004 -G 9997 -G 1015 $user_uid -s "$WRAPPER_SCRIPT"
